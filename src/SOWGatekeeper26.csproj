<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>SOWGatekeeper26</AssemblyName>
    <ApplicationIcon>discord-bot.ico</ApplicationIcon>
    <Deterministic>true</Deterministic>
    <Product>SOW Gatekeeper 26</Product>
    <AssemblyTitle>SOW Gatekeeper 26</AssemblyTitle>
    <Description>SOW Gatekeeper 26 — Project Zomboid Discord bot. https://github.com/erneare85/PZServerDiscordBot</Description>
    <Version>1.0.0.2</Version>
    <AssemblyVersion>1.0.0.2</AssemblyVersion>
    <FileVersion>1.0.0.2</FileVersion>
    <Copyright>Copyright © 2022</Copyright>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <DefineConstants>$(DefineConstants);EXPORT_DEFAULT_LOCALIZATION</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Discord.Net" Version="3.18.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="System.Management" Version="10.0.0" />
  </ItemGroup>
</Project>
